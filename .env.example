# SQL Server
SQLSERVER_SA_PASSWORD=your-strong-password-here

# PostgreSQL
POSTGRES_USER=pilotbase
POSTGRES_PASSWORD=your-postgres-password-here
POSTGRES_DB=pilotbase_ops

# MongoDB
MONGO_ROOT_USERNAME=pilotbase
MONGO_ROOT_PASSWORD=your-mongo-password-here
